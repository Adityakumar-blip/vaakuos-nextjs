# Public site URL (used for canonical URLs, sitemap, SEO)
NEXT_PUBLIC_SITE_URL=https://vaakuos.com

# Supabase (anon key is public-by-design, protected by Row-Level Security)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend API base URL. Defaults to https://api.vaakuos.com if unset.
# For local development against a local backend, set http://localhost:3001/
NEXT_PUBLIC_API_URL=https://api.vaakuos.com

# Google Identity Services client ID (Google Cloud Console -> Credentials).
# Required for the "Continue with Google" button on /login and /signup.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Analytics (all optional, all client-side/public)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
NEXT_PUBLIC_MIXPANEL_TOKEN=
